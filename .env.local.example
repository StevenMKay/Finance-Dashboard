# Required: get a free key at https://finnhub.io
FINNHUB_API_KEY=your_finnhub_api_key_here

# Optional: comma-separated list of allowed origins for the /api/quote CORS check.
# Leave blank to allow same-origin only (default during `vercel dev` is localhost).
ALLOWED_ORIGINS=https://finance-dashboard-yourname.vercel.app
