# Required for /api/quote: get a free key at https://finnhub.io
FINNHUB_API_KEY=your_finnhub_api_key_here

# Required for /api/bars (Strategy Backtester live data).
# Get a free key at https://polygon.io. Leave blank during local dev to
# fall back to in-browser mock candles (the page shows a banner).
POLYGON_API_KEY=

# Required for /api/ai-recommend and /api/ai-strategy (Strategy Lab AI).
# Leave blank to disable AI features (page shows a disabled banner).
OPENAI_API_KEY=

# Required for verifying Firebase ID tokens on AI endpoints.
# Copy these from your Firebase project's service-account JSON.
# The private key must keep its real newlines OR be escaped as \n.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Optional: comma-separated list of allowed origins for /api CORS checks.
# Leave blank to allow same-origin only (default during `vercel dev` is localhost).
ALLOWED_ORIGINS=https://finance-dashboard-yourname.vercel.app
